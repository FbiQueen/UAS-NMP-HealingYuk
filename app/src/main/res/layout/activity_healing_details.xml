<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HealingDetailsActivity">

    <ImageView
        android:id="@+id/ivDetailImage"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:scaleType="centerCrop"
        android:src="@drawable/labuanbajo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="Detail Place Image" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddRemoveFavorite"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
    android:text="Add to Favourite"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="16dp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:backgroundTint="@color/black"
    app:icon="@drawable/baseline_favorite_24" app:iconTint="@android:color/white"
    style="@style/Widget.MaterialComponents.Button" />

    <TextView
        android:id="@+id/tvDetailName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:textSize="22sp"
        android:textStyle="bold"
    tools:text="Pulau Padar"
    app:layout_constraintTop_toBottomOf="@id/ivDetailImage"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvDetailCategory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:textSize="16sp"
    tools:text="Labuan Bajo"
    app:layout_constraintTop_toBottomOf="@id/tvDetailName"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvDetailCategory"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
        tools:text="Pulau Padar merupakan salah satu pulau di Taman Nasional Komodo yang terkenal dengan pemandangan alamnya yang indah. Pulau Padar memiliki bukit-bukit yang terjal, pantai berpasir putih, dan air laut yang biru jernih. Dari puncak bukit ini, kamu dapat menikmati pemandangan indah berupa tiga teluk yang berbentuk melengkung.\n\nAktivitas utama di Pulau Padar adalah hiking ke puncak bukit untuk menikmati pemandangan. Selain itu, kamu juga bisa snorkeling dan diving di sekitar pulau untuk menyaksikan keindahan bawah lautnya. Selain itu, untuk kamu yang hobi fotografi, Pulau Padar adalah tempat terbak karena pemandangannya yang sangat fotogenik.\n\nAlamat : Pulau Padar, Taman Nasional Komodo, Labuan Bajo, Nusa Tenggara Timur."  />
    </ScrollView>

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/baseline_arrow_back_ios_24" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Back" />

</androidx.constraintlayout.widget.ConstraintLayout>